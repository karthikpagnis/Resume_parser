# Resume Parser Configuration
# Copy this file to .env and update values as needed

# Model Configuration
MODEL_NAME=distilbert-base-uncased
NER_MODEL=dbmdz/bert-base-cased-finetuned-conll03-english
ZERO_SHOT_MODEL=facebook/bart-large-mnli

# File Configuration
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE_MB=50
TEMP_FOLDER=/tmp/resume_parser

# Processing Configuration
BATCH_SIZE=1
NUM_WORKERS=1
USE_GPU=auto

# API Configuration (for Flask app)
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=resume_parser.log
VERBOSE=False

# Cache Configuration
HF_HOME=~/.cache/huggingface
DISABLE_HF_HUB=False

# Performance Configuration
DEVICE=cuda  # or cpu
PRECISION=float32  # or float16 for mixed precision
